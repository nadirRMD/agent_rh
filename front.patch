+  box-shadow: 0 0 0 4px rgba(124, 77, 47, 0.1);
+}
+
+.composer button {
+  justify-self: start;
+  padding: 0.9rem 1.25rem;
+  background: var(--accent);
+  color: #fff;
+  box-shadow: 0 12px 24px rgba(124, 77, 47, 0.22);
+}
+
+.composer button:disabled {
+  opacity: 0.7;
+  cursor: progress;
+}
+
+.response {
+  margin-top: 22px;
+}
+
+.response h2 {
+  margin: 0;
+  font-size: 1.1rem;
+}
+
+.response-head span {
+  color: var(--muted);
+  font-size: 0.88rem;
+}
+
+.response-box {
+  min-height: 140px;
+  margin: 14px 0 0;
+  padding: 18px;
+  border-radius: 20px;
+  background: rgba(255, 255, 255, 0.78);
+  border: 1px solid rgba(91, 68, 50, 0.12);
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+  line-height: 1.55;
+}
+
+.response-box.error {
+  color: #8a2e1f;
+  background: rgba(255, 236, 233, 0.9);
+}
+
+.login-shell {
+  display: grid;
+  place-items: center;
+}
+
+.login-panel {
+  width: min(560px, 100%);
+  background: var(--panel);
+  backdrop-filter: blur(16px);
+  border: 1px solid var(--panel-border);
+  border-radius: 28px;
+  box-shadow: var(--shadow);
+  padding: 32px;
+}
+
+.login-panel h1 {
+  max-width: none;
+  margin-top: 6px;
+}
+
+@media (max-width: 900px) {
+  .hero {
+    grid-template-columns: 1fr;
+  }
+
+  h1 {
+    max-width: 100%;
+  }
+}
